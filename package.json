{
  "name": "nvim_typescript_ls_project",
  "version": "1.0.0",
  "description": "Project initialized for TypeScript/Node.js",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "npm run check && tsc",
    "check": "tsc --noEmit",
    "lint": "npm run format && eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "type": "commonjs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.59.1"
  }
}
